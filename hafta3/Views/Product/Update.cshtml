@{
    ViewData["Title"] = "Update";
}

<h1>Update Page</h1>
@model Product


<form asp-controller="Product" asp-action="UpdateProduct" method="post">
    
    <input type="hidden" asp-for="Id" />

    <label>Product Name: </label>
    <input type="text" asp-for="Name" />

    <label>Product Stok: </label>
    <input type="text" asp-for="Stok" />

    <label>Product Price: </label>
    <input type="text" asp-for="Price" />

    <label>Product Color: </label>
    <input type="text" asp-for="Color" />

    <label>Product Description: </label>
    <input type="text" asp-for="Description" />

    <label>Product Ozellik: </label>
    <input type="text" asp-for="ozellik" />

    <button type="submit">Update</button>

</form>